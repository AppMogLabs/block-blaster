# ─── Privy (client + server) ──────────────────────────────────────────────
# Create an app at https://dashboard.privy.io — enable X/Twitter OAuth.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── MegaETH RPC ───────────────────────────────────────────────────────────
# Mainnet: https://mainnet.megaeth.com/rpc   (chainId 4326)
# Testnet: https://carrot.megaeth.com/rpc    (chainId 6343) — default for dev
MEGAETH_RPC_URL=https://carrot.megaeth.com/rpc
NEXT_PUBLIC_MEGAETH_RPC_URL=https://carrot.megaeth.com/rpc
NEXT_PUBLIC_MEGAETH_CHAIN_ID=6343
NEXT_PUBLIC_MEGAETH_EXPLORER=https://megaeth-testnet-v2.blockscout.com

# ─── Backend signer (server-only) ──────────────────────────────────────────
# Must be the OWNER of both BLOK and Leaderboard contracts.
# Fund it with a tiny amount of ETH for gas (base fee is 0.001 gwei).
BACKEND_WALLET_PRIVATE_KEY=

# ─── Deployed contracts ────────────────────────────────────────────────────
BLOK_CONTRACT_ADDRESS=
LEADERBOARD_CONTRACT_ADDRESS=
NEXT_PUBLIC_BLOK_CONTRACT_ADDRESS=
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ADDRESS=

# ─── Session signing ───────────────────────────────────────────────────────
# 32+ random bytes; generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Persistent session store (recommended for production) ─────────────────
# Vercel KV or Upstash Redis REST endpoint. If both are unset, the app falls
# back to an in-memory Map, which is UNSAFE across multiple serverless
# instances — sessions can be replayed on a cold-started node.
KV_REST_API_URL=
KV_REST_API_TOKEN=
